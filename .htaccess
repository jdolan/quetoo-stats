RewriteEngine On

# Route /api/stats/<guid> -> api/stats.php?guid=<guid>
RewriteRule ^api/stats/([a-f0-9]{64})/?$ api/stats.php?guid=$1 [L,QSA]

# Route /api/<name> -> api/<name>.php
RewriteRule ^api/([a-z_]+)/?$ api/$1.php [L,QSA]

# Block direct access to config files
<FilesMatch "^config.*\.php$">
  Require all denied
</FilesMatch>
